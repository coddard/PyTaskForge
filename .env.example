# ============================================================
# PyTaskForge — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in all required values:
#   cp .env.example .env
#
# !! NEVER commit your .env file to version control !!
# ============================================================


# ── Application ──────────────────────────────────────────────
APP_NAME=PyTaskForge
APP_VERSION=2.0.0

# Enable SQLAlchemy query echo and verbose logging.
DEBUG=false


# ── Security ─────────────────────────────────────────────────
# REQUIRED in production (PTF_DEV_MODE=false).
# Generate a strong key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING

# JWT algorithm (do not change unless you know what you're doing).
ALGORITHM=HS256

# JWT token lifetime in minutes (default: 480 = 8 hours).
ACCESS_TOKEN_EXPIRE_MINUTES=480


# ── Developer Mode ───────────────────────────────────────────
# Setting PTF_DEV_MODE=true DISABLES all authentication.
# NEVER enable this in a production environment.
PTF_DEV_MODE=false


# ── Bootstrap Admin Account ──────────────────────────────────
# These credentials are used to create the initial admin user
# on first startup. Change them immediately after the first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
ADMIN_EMAIL=admin@your-domain.com


# ── Database ─────────────────────────────────────────────────
# SQLite (default — suitable for single-server deployments):
DATABASE_URL=sqlite+aiosqlite:////app/data/pytaskforge.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pytaskforge


# ── Logging ──────────────────────────────────────────────────
# LOG_FORMAT=text  → human-readable (development / local)
# LOG_FORMAT=json  → structured JSON (production / log aggregators)
LOG_FORMAT=text


# ── Concurrency ──────────────────────────────────────────────
# Maximum number of jobs that can execute simultaneously.
# Increase with caution — each venv job creates a subprocess.
MAX_CONCURRENT_JOBS=10


# ── VaultGuard Encryption Key ────────────────────────────────
# REQUIRED if you use the Secrets Manager feature.
# Generate a key (do this ONCE and store it safely):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# WARNING: Losing this key means ALL stored secrets are permanently lost.
VAULT_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY


# ── Docker Execution Defaults ────────────────────────────────
DOCKER_DEFAULT_IMAGE=python:3.11-slim
# "none" = no network access (maximum isolation).
# Use "bridge" if scripts need internet access in Docker mode.
DOCKER_NETWORK=none
DOCKER_MEM_LIMIT=256m
DOCKER_CPU_PERIOD=100000
# CPU quota: 50000 = 50% of one core. Set to 100000 for full core.
DOCKER_CPU_QUOTA=50000


# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production, replace with your actual frontend URL.
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

